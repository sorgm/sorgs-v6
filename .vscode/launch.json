{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "HTTP server + browser (simple)",
      "type": "debugpy",
      "request": "launch",
      "module": "http.server",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "port ([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "killOnServerStop": true,
        "action": "debugWithEdge"
        //run as first action after restart - don't start edge manually
      }
    }
  ]
}